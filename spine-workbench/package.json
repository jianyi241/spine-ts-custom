{
  "name": "spine-workbench",
  "version": "1.0.0",
  "description": "Spine 资源提取、预览与下载工作台",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.mjs",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server/index.mjs"
  },
  "dependencies": {
    "@esotericsoftware/spine-core": "4.2.56",
    "archiver": "^7.0.1",
    "bootstrap": "^5.3.8",
    "express": "^5.2.1",
    "gsap": "^3.13.0",
    "react": "^19.2.0",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.0",
    "three": "0.146.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "vite": "^8.0.9"
  }
}
